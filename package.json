{
  "name": "@tamtamchik/apple-iap-tools",
  "version": "1.4.0-pre.6",
  "description": "Apple IAP tools for Node.js. Verify receipts and handle Apple Server Notifications.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "author": "Yuri Tkachenko <yuri.tam.tkachenko@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/tamtamchik/apple-iap-tools#readme",
  "bugs": {
    "url": "https://github.com/tamtamchik/apple-iap-tools/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/tamtamchik/apple-iap-tools.git"
  },
  "directories": {
    "doc": "docs"
  },
  "keywords": [
    "Apple Server Notifications",
    "Apple verifyReceipt",
    "Apple IAP"
  ],
  "devDependencies": {
    "@peculiar/x509": "^2.0.0",
    "@stylistic/eslint-plugin": "^2.13.0",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^8.57.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "reflect-metadata": "^0.2.2",
    "tsdown": "^0.21.10",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "jose": "^6.2.3"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "npm run build -- --watch src",
    "lint": "eslint src test --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage \"--coverage.include=src/**\"",
    "docs": "typedoc",
    "docs:serve": "npx http-server docs",
    "prepublishOnly": "npm run build && npm run docs"
  }
}
